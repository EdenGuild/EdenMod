{
  "schemaVersion": 1,
  "id": "eden-bridge",
  "version": "${version}",
  "name": "EdenMod",
  "description": "EdenMod — the companion mod for members of the Eden Wynncraft Guild.",
  "authors": ["Eden Guild"],
  "icon": "assets/eden-bridge/icon.png",
  "contact": {
    "homepage": "https://github.com/EdenGuild"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
